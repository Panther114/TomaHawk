{
  "name": "tomahawk",
  "version": "0.3.0",
  "private": true,
  "description": "战斧 / TomaHawk — a deterministic, local-first 2D modern battle simulator (browser + Node, no build step).",
  "license": "LicenseRef-PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.mjs",
    "refresh:start": "node scripts/build-east-china-sea-map.mjs && node server.mjs",
    "test": "node --test tests/",
    "bench": "node scripts/bench.mjs",
    "bench:terrain": "node scripts/bench-terrain.mjs",
    "bench:frontend": "node scripts/bench-frontend.mjs",
    "debug:sim": "node --expose-gc scripts/sim-debug.mjs",
    "map:data": "node scripts/build-east-china-sea-map.mjs"
  }
}
